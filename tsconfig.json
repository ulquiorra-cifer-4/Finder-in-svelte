{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target":    "ESNext",
    "useDefineForClassFields": true,
    "module":    "ESNext",
    "moduleResolution": "bundler",
    "strict":    true,
    "noEmit":    true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
